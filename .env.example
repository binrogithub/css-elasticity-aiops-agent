# AI provider
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=replace-me
OPENAI_MODEL=gpt-4o-mini
AI_MAX_RETRIES=2
AI_RETRY_BACKOFF_SECONDS=1.0

# Scheduler
RESOURCE_CHECK_INTERVAL_SECONDS=300
AI_CHECK_INTERVAL_SECONDS=1800

# Spike thresholds
CPU_SPIKE_THRESHOLD=80
LATENCY_SPIKE_THRESHOLD=500
REJECTED_SPIKE_THRESHOLD=1
QPS_SPIKE_THRESHOLD=2.0

# Elasticity boundaries
MIN_NODES=1
MAX_NODES=5
INITIAL_NODES=2
DEFAULT_COOLDOWN_MINUTES=30
CSS_NODE_LIMITS_JSON=
CSS_DEFAULT_DATA_MIN=1
CSS_DEFAULT_DATA_MAX=32
CSS_DEFAULT_CLIENT_MIN=0
CSS_DEFAULT_CLIENT_MAX=64
CSS_DEFAULT_MASTER_ALLOWED_COUNTS=0,3,5,7,9
CSS_ALLOW_FLAVOR_CHANGE=true
CSS_ALLOW_ADD_INDEPENDENT_NODES=true
AGENT_RUN_MODE=recommend-only
CSS_MUTATION_ENABLED=false
ENTERPRISE_POLICY_PROFILE=standard
POLICY_VERSION=enterprise-policy-v1
MAINTENANCE_WINDOW_UTC=
MAX_SCALING_ACTIONS_PER_DAY=2
MAX_SCALE_OUT_PERCENT=20
SCALE_OUT_OBSERVATION_MINUTES=60
SCALE_IN_LOW_LOAD_MINUTES=120
FAST_SCALE_IN_REVIEW_ENABLED=true
CSS_CLIENT_SCALE_OUT_MAX_DELTA=0
CSS_CLIENT_SCALE_IN_MAX_DELTA=0
CSS_DATA_SCALE_OUT_MAX_DELTA=0
CSS_DATA_SCALE_IN_MAX_DELTA=0
CSS_CLIENT_SCALE_OUT_COOLDOWN_MINUTES=30
CSS_CLIENT_SCALE_IN_COOLDOWN_MINUTES=10
CSS_DATA_SCALE_OUT_COOLDOWN_MINUTES=45
CSS_DATA_SCALE_IN_COOLDOWN_MINUTES=120
AUTO_EXECUTE_NODE_TYPES=ess-client
APPROVAL_REQUIRED_ACTIONS=ess:scale_in,ess-master:scale_out,ess-master:scale_in,change_flavor
CSS_DATA_SCALE_IN_ALLOWED=false
CSS_TRAFFIC_ENTRY_MODE=unknown
CSS_CLIENT_SCALE_IN_ALLOWED=false
CSS_DEFAULT_VOLUME_TYPE=COMMON
CSS_DEFAULT_MASTER_VOLUME_SIZE=40
CSS_DEFAULT_CLIENT_VOLUME_SIZE=40

# Persistence and logs
SQLITE_DB_PATH=data/agent.sqlite3
LOG_DIR=data/logs
LOG_LEVEL=INFO
JSON_LOGS=false

# Cluster metadata
CLUSTER_ID=replace-me
CLUSTER_NAME=replace-me

# Provider selection: use real CSS/CES for production runs.
METRICS_PROVIDER=css
EXECUTOR_PROVIDER=css
DIAGNOSTICS_PROVIDER=disabled
OPENSEARCH_ENDPOINT=
OPENSEARCH_USERNAME=
OPENSEARCH_PASSWORD=
OPENSEARCH_VERIFY_TLS=false
OPENSEARCH_TIMEOUT_SECONDS=10
SHARD_SEARCH_MIN_GB=10
SHARD_SEARCH_MAX_GB=30
SHARD_GENERAL_MAX_GB=50
MAX_SHARDS_PER_GB_HEAP=25
MAX_STORAGE_SKEW_RATIO=1.5
MAX_SHARD_SKEW_RATIO=1.5

# Huawei Cloud CSS/CES runtime values. Do not commit real secrets.
HUAWEICLOUD_SDK_AK=replace-me
HUAWEICLOUD_SDK_SK=replace-me
HUAWEICLOUD_REGION=replace-me
HUAWEICLOUD_PROJECT_ID=replace-me
HUAWEICLOUD_IAM_ENDPOINT=https://iam.myhuaweicloud.com
HUAWEICLOUD_CSS_ENDPOINT=
HUAWEICLOUD_CES_ENDPOINT=
CSS_NODE_TYPE=ess-client
CSS_VERIFY_TIMEOUT_SECONDS=900
CSS_VERIFY_POLL_INTERVAL_SECONDS=30
CSS_BLOCKING_VERIFICATION=false
CSS_COUNT_SCALE_TIMEOUT_MINUTES=30
CSS_FLAVOR_CHANGE_TIMEOUT_MINUTES=60
